# ─────────────────────────────────────────────────────────────────────────
# Flow Ledger — Waitlist backend configuration
# Copy this file to `.env` locally, and set the same keys in Netlify's
# Site settings → Environment variables for production/deploy previews.
# Nothing in this file is ever sent to the browser — it's only read inside
# server functions (src/server/*.ts).
# ─────────────────────────────────────────────────────────────────────────

# --- Email delivery (required for admin + confirmation emails) ------------
# Resend: https://resend.com — create an API key and a verified sending
# domain/address.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Flow Ledger <hello@yourdomain.com>"

# Where visitor-signup notifications are sent.
ADMIN_NOTIFICATION_EMAIL=you@example.com

# --- Storage: choose ONE backend below (optional but recommended) --------

# Option A — Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Waitlist

# Option B — Supabase (used only if Airtable vars above are unset)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TABLE_NAME=waitlist

# --- Optional: durable rate limiting across serverless instances ----------
# Without these, rate limiting still works but is per-instance only
# (see src/server/rateLimit.ts).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
